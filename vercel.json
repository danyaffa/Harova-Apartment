{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "public/*.css", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "llms.txt", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/llms.txt", "dest": "/llms.txt" },
    { "src": "/gallery.html", "dest": "/gallery.html" },
    { "src": "/location.html", "dest": "/location.html" },
    { "src": "/contact.html", "dest": "/contact.html" },
    { "src": "/ai-discovery.html", "dest": "/ai-discovery.html" },
    { "src": "/gallery", "dest": "/gallery.html" },
    { "src": "/location", "dest": "/location.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/ai-discovery", "dest": "/ai-discovery.html" },
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    }
  ]
}
